{
  "expo": {
    "name": "AmperEX",
    "slug": "AmperEX",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_rounded.png",
    "scheme": "amperex",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "La app necesita acceso a la cámara para escanear códigos QR.",
        "NSLocationWhenInUseUsageDescription": "La app necesita tu ubicación para mostrarla en el mapa."
      },
      "bundleIdentifier": "com.amperexspa.AmperEX",
      "config": {
        "googleMapsApiKey": "AIzaSyCKqF-sV4dfbD_aOf3Y4vG3w39AHs_dPUE"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon_rounded.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.amperexspa.AmperEX",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDIjVkEGxgUzIAFiGd4wCFtgTh89VI6Fn4"
        }
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Usar Face ID para autorizar pagos con tu tarjeta inscrita."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon_rounded.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon_rounded.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "cf6986b3-683b-4e0e-829d-6babc0166f9a"
      }
    }
  }
}