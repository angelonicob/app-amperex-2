# Copia este archivo a .env y configura tus valores reales
# cp .env.template .env

# Stage: dev | production
STAGE=dev

# URL base de la API
API_URL=http://localhost:4000/api/v1/mobile

# URLs específicas por plataforma (opcional, por defecto usan API_URL)
# Para Android emulator usa 10.0.2.2, para dispositivo físico usa tu IP local
API_URL_IOS=http://localhost:4000/api/v1/mobile
API_URL_ANDROID=http://10.0.2.2:4000/api/v1/mobile

# Opcional (otros scripts / documentación).
EXPO_ACCOUNT_OWNER=

# Firebase (para Auth en la app)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
