# App móvil Amperex (Expo) — copiar a .env
# cp .env.template .env
#
# Leídas en app.config.js → extra. Valores comentados = default en app.config.js.

# -----------------------------------------------------------------------------
# API (src/infrastructure/http/Api.ts)
# -----------------------------------------------------------------------------
# dev: iOS/Android usan URLs por plataforma; production: solo API_URL
# STAGE=dev
API_URL=http://localhost:3000/api/v1/mobile
# Si no se define, heredan API_URL
API_URL_IOS=http://localhost:3000/api/v1/mobile
# Emulador Android → host del PC
API_URL_ANDROID=http://10.0.2.2:3000/api/v1/mobile

# -----------------------------------------------------------------------------
# Firebase Auth (requeridas para login en la app)
# -----------------------------------------------------------------------------
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# Android push / FCM (app.config.js)
# -----------------------------------------------------------------------------
# Local: ./keys/google-services.json (no versionado)
# EAS Build: variable tipo FILE en expo.dev
# GOOGLE_SERVICES_JSON=
